# URL pública del sitio (usada por ej. en el link de redirección de las
# invitaciones de equipo — supabase.auth.admin.inviteUserByEmail).
NEXT_PUBLIC_SITE_URL=https://dulabs.co

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # clave pública (anon), protegida por RLS — segura de exponer al cliente

# Cifra meta_permanent_token y api_key_ia antes de guardarlos (ver lib/crypto.ts)
# — así un dump de la base o la service-role key filtrada no exponen los
# tokens en texto plano. Generar UNA vez con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Guardar el mismo valor en Vercel y nunca rotarlo sin antes descifrar los
# valores existentes con la clave vieja.
TOKEN_ENCRYPTION_KEY=

# Meta / WhatsApp Cloud API
META_VERIFY_TOKEN=un-token-secreto-que-tu-eliges
META_ACCESS_TOKEN=EAAG...   # System User token con whatsapp_business_messaging
META_GRAPH_VERSION=v23.0

# IA por defecto de la plataforma (si el cliente no trae su propia api_key_ia)
ANTHROPIC_API_KEY=sk-ant-...

# Embedded Signup v4 (Meta for Developers → tu app)
NEXT_PUBLIC_META_APP_ID=1234567890
NEXT_PUBLIC_META_CONFIG_ID=2187855688668857
META_APP_SECRET=abc123...

# Pagos recurrentes (Wompi — comercios.wompi.co → Desarrolladores)
# Usa las llaves test_ en Sandbox antes de pasar a prod_ en producción.
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_KEY=...   # para verificar la firma de los webhooks de Wompi
WOMPI_INTEGRITY_KEY=...   # para firmar la creación de transacciones (campo "signature")
CRON_SECRET=un-secreto-que-tu-eliges   # protege /api/wompi/cobro-mensual
